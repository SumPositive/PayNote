    "%@" : {
      "comment" : "A picker option in the \"Closing day\" section of the card edit view, representing a day of the month. The value of the option is the day number (1-28, or 29 for",
      "isCommentAutoGenerated" : true
    },
    "+ %@" : {
      "comment" : "A label indicating that a part's amount includes interest.",
      "isCommentAutoGenerated" : true
    },
    "✕ %@" : {
      "comment" : "A note indicating that there are unpaid items in the invoice.",
      "isCommentAutoGenerated" : true
    },
