    "record.help.label" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the main label shown in lists. Enter store/purpose/context clearly. You can change it anytime, and select from recent similar labels below."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一覧で目印になるラベルです。店名や目的など、あとで分かる短い言葉を入れてください。あとで変更できます。下の候補から選ぶこともできます。"
          }
        }
      }
