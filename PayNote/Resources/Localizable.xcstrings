    "record.help.repeat" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use this for monthly or yearly recurring payments. A new payment is created automatically when the current one is marked paid."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎月・毎年など定期的な決済に使います。引き落とし済みにすると、次回分を自動で作成します。"
          }
        }
      }
    },
    "record.help.tag" : {
