    "card.edit.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please register payment methods that will be withdrawn from your account later. Credit-type and charge-type payments are supported. For example, with PayPay, record only charge-based payments. Do not record each individual use. Payments that are withdrawn immediately, such as debit or cash charge, are not supported."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "後日、口座から引き落とされる決済方法を登録してください。クレジット式やチャージ式の決済が対象です。例えばPayPayならばチャージ決済だけを記録します。毎回の利用は記録しません。デビットや現金チャージなど即時に引き落とされる決済は対象外です。"
          }
        }
      }
    },
