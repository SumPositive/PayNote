    "card.edit.beginner.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give your card a short nickname. This app does not encrypt data, so avoid sensitive info. If you include card digits, only the last 3 are safe to store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クレジットカードの名称などを短い呼び名をつけてください。暗号化しませんので機密情報は入れず、カード番号を入れるならば下3桁までが安全です。"
          }
        }
      }
    },
    "settings.help.openAddOnActive": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, opens the new payment screen automatically each time you return to the app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにするとアプリを再表示したとき、自動的に新しい決済入力画面を開きます。"
          }
        }
      }
    },
    "settings.help.afterSave": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose what happens after saving a new payment. Use Continuous Entry for back-to-back entries."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい決済を保存した後の画面遷移を選べます。連続して入力するなら「連続入力」が便利です。"
          }
        }
      }
    },
    "settings.help.paymentWindow": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Number of days shown in the Debit Status screen. For example, 7 days shows totals due within 7 days from today. Use this as a reference for preparing funds."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「引き落とし状況」画面に表示する引き落とし合計の集計日数です。例えば7日にすると、今日から7日以内の引き落とし合計を表示します。資金準備の参考にしてください。"
          }
        }
      }
    },
    "bank.edit.beginner.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give your account a short nickname. This app does not encrypt data, so avoid sensitive info. If you include account digits, only the last 3 are safe to store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "銀行名など短い呼び名をつけてください。暗号化しませんので機密情報は入れず、口座番号を入れるならば下3桁までが安全です。"
          }
        }
      }
    },
    "settings.showCurrencySymbol": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show Currency Symbol (¥)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通貨記号(¥)を表示する"
          }
        }
      }
    }
  },
  "version": "1.1"
