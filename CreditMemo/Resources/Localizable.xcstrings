        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この決済が引き落とし済みになった時、利用日を翌月などの指定日にした新しい決済を自動追加します。"
          }
        }
      }
    },
    "record.help.tag": {
      "extractionState": "manual",
