    "migration.legacy.failed.message": {
      "comment": "A message in the checkout view explaining that the user can either send their old data to you or start over by discarding it. The argument is the string “sumpo@azukid.com”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "value": "旧アプリのデータ読み出しに失敗しました。旧アプリのデータを送って頂ければ調査対応します。送信先: %@",
            "state": "translated"
          }
        },
        "en": {
          "stringUnit": {
            "value": "Couldn't read legacy app data. Please send it for investigation. Send to: %@",
            "state": "translated"
          }
        }
      }
    },
    "migration.legacy.send": {
      "comment": "A button label for sharing the user's legacy store via email.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "value": "旧データをメールで送る",
            "state": "translated"
          }
        },
        "en": {
          "stringUnit": {
            "value": "Send Legacy Data by Email",
            "state": "translated"
          }
        }
      }
    },
    "migration.legacy.discard": {
      "comment": "A button label that, when tapped, will discard the user's legacy data and start a new migration process.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "value": "旧データを破棄して新しく始める",
            "state": "translated"
          }
        },
        "en": {
          "stringUnit": {
            "value": "Discard Legacy Data and Start Fresh",
            "state": "translated"
          }
        }
      }
    },
    "migration.legacy.thanks": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "value": "送信ありがとうございました。このまま次のアップデートをお待ちください",
            "state": "translated"
          }
        },
        "en": {
          "stringUnit": {
            "value": "Thanks for sending. Please wait for the next update.",
            "state": "translated"
          }
        }
      }
    }
  },
  "version": "1.1"
