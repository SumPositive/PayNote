    "top.beginner.guide": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Start with New Payment. You can save amount first and fix the rest later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まずは「新しい決済」から始めてください。金額だけでも保存できます。足りない情報はあとから直せます。"
          }
        }
      }
    },
    "top.beginner.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Getting Started"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "はじめに"
          }
        }
      }
    },
    "top.cardList": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay Methods"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "決済手段"
          }
        }
      }
    },
    "top.help.addRecord": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Start here. Save amount first, then edit the rest later from history."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まずここから入力します。金額だけ先に入れて、残りはあとで履歴から編集できます。"
          }
        }
      }
    },
    "top.help.bankList": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Register debit accounts. Simple names are fine. Move entries between Unpaid and Paid per account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "引き落とし口座を登録します。簡単な名前でも大丈夫です。口座ごとに未払と引き落とし済みを切り替えます。"
          }
        }
      }
    },
    "top.help.cardList": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Register names of cashless payment methods. Presets can be edited or removed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュレス決済手段の名前を登録します。プリセットは編集・削除できます。"
          }
        }
      }
    },
    "top.help.paymentList.line1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Check this status regularly."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画面を定期的に確認してください"
          }
        }
      }
    },
    "top.help.paymentList.line2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If account debit is confirmed,"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "口座の引き落としを確認したら、"
          }
        }
      }
    },
    "top.help.paymentList.line3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": " tap to move it to Paid."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "をタップして引き落とし済みにします"
          }
        }
      }
    },
    "top.help.paymentList.line4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "You can always move it back to Unpaid."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "必要ならいつでも未払に戻せます"
          }
        }
      }
    },
    "top.help.recordList": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Newest first. Tap to edit. You can also filter to entries with missing info."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい順に表示されます。タップして編集できます。不足項目のある決済だけを見ることもできます。"
          }
        }
      }
    },
    "top.help.settings": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Set User Level to Expert to hide these tips."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザレベルを達人にすると、この説明文が消えます"
          }
        }
      }
    },
    "top.help.tagList": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "You can add multiple tags per payment. Tags enable tag-based lists and summaries."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "決済ごとにタグを複数付けられます。タグを付けると、タグ別の一覧や集計ができます。"
          }
        }
      }
    },
    "top.paymentList": {
