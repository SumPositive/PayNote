    "record.help.repeat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use for monthly/yearly recurring payments. When marked paid, the next one is auto-created."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎月・毎年など定期的な決済に使います。引き落とし済みにすると、次回分を自動で作成します。"
          }
        }
      }
    },
