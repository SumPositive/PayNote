    "card.field.closingDay.enHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Spending after this day rolls to the next month. If not set, it matches the payment due day."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この日以降の利用は翌月に繰り越します。未設定ならば支払日と同じになります。"
          }
        }
      }
    },
