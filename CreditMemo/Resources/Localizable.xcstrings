    "alert.deleteConfirm.bank.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This action can't be undone. Accounts in payment history will be set to Not Set. You can set them again later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作は取り消せません。決済履歴は消えません。口座が未設定に変わるだけです。改めて設定することが可能です"
          }
        }
      }
    },
