    "settings.help.import": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import an exported JSON file. Importing the same file again updates it without duplicates."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エキスポートしたファイル(JSON)を読み込みます。同じファイルを読み込んでも重複せずに上書きします。"
          }
        }
      }
    },
    "settings.help.retention": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too much data may slow things down. Even 15 years should work, but about 3 years fits this app better."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データが溜まりすぎると動作が遅くなる可能性があります。想定では15年でも大丈夫ですが、このアプリの目的では3年くらいが適切であると考えています。適時整理して3年分くらいでご利用ください。"
          }
        }
      }
    },
    "settings.help.userLevel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginner shows more help. Expert hides most tips. Switch to Expert when you're comfortable."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "初心者は説明を多めに表示します。達人にすると説明を減らし、詳細メニューを表示します。使い慣れて流れが分かってきたら、達人に切り替えてください。"
          }
        }
      }
    },
