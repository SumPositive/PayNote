    "card.help.manageLevel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This only shows your self-management style. It does not affect processing. Choose how strict you want to track, and change anytime."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "管理の厳しさを示す設定です。計算や処理には影響しません。あとでいつでも変更できます。"
          }
        }
      }
    },
    "card.help.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Register payment methods that are debited from your account later. For PayPay, credit-linked use and wallet top-up are included. Spending topped-up PayPay balance is excluded."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "後日、口座から引き落とされる決済手段の名称を登録します。PayPayならばクレジット連携の利用やPayPay残高へのチャージが決済対象になります。チャージしたPayPay残高の利用は対象外です。"
          }
        }
      }
    },
    "card.help.schedule": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set the closing day and payment day for this method. Check your card documents or contact the issuer if unknown."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この決済手段の締日と支払日を設定します。わからない場合はカード会社に確認し、実際の引き落とし日で調整してください。"
          }
        }
      }
    },
